<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('partials/head') %>
<title>Bautista Law Office | Analytics Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    font-family: 'Inter', sans-serif;
    height: 100vh;
    background: linear-gradient(135deg, #eef2f0 0%, #e0e8e3 100%);
    display: flex;
    overflow: hidden;
}
.sidebar {
    width: 280px;
    background: linear-gradient(180deg, #1a3a32 0%, #0f2c24 100%);
    color: #fef5e7;
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.08);
    z-index: 10;
}
.sidebar-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(219, 184, 107, 0.3);
}
.sidebar-icon {
    background: #dbb86b;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
}
.sidebar-icon i { color: #1a3a32; }
.sidebar-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #f7eac5;
}
.sidebar-header span { font-size: 0.7rem; opacity: 0.7; display: block; }
.sidebar-nav { flex: 1; display: flex; flex-direction: column; gap: 8px; margin-top: 20px; }
.sidebar a {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    color: #e2e6dc;
    text-decoration: none;
    font-weight: 500;
    border-radius: 14px;
    transition: all 0.25s ease;
}
.sidebar a i { width: 24px; font-size: 1.2rem; }
.sidebar a:hover { background: rgba(219, 184, 107, 0.18); color: #ffefcf; transform: translateX(5px); }
.sidebar a.active { background: #dbb86b; color: #1e2f28; font-weight: 600; }
.sidebar a.active i { color: #1a3a32; }
.logout-link { margin-top: auto; border-top: 1px solid rgba(219, 184, 107, 0.2); padding-top: 20px; }
.logout-link a { color: #f0cf9a; }
/* MAIN */
.main { flex: 1; padding: 30px 36px; overflow-y: auto; }
.page-header { margin-bottom: 32px; }
.page-header h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 600;
    color: #1e4238;
    display: flex;
    align-items: center;
    gap: 12px;
}
.page-header h1 i { background: #dbb86b20; padding: 10px; border-radius: 50%; color: #b8863f; }
.page-desc { color: #5a6e64; margin-top: 8px; border-left: 3px solid #dbb86b; padding-left: 16px; }
/* Stats Row */
.stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
    margin-bottom: 32px;
}
.stat-card {
    background: white;
    border-radius: 28px;
    padding: 24px;
    text-align: center;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.04);
    transition: transform 0.2s;
}
.stat-card:hover { transform: translateY(-4px); }
.stat-card i { font-size: 2.5rem; color: #dbb86b; margin-bottom: 12px; }
.stat-card h3 { font-size: 2rem; color: #1e4238; font-weight: 700; }
.stat-card p { color: #7a8e82; font-weight: 500; }
/* Charts Grid */
.charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 28px;
    margin-bottom: 32px;
}
.chart-card {
    background: white;
    border-radius: 28px;
    padding: 24px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05);
}
.chart-card h3 {
    font-family: 'Cormorant Garamond', serif;
    color: #2c5a4a;
    margin-bottom: 20px;
    font-size: 1.3rem;
}
canvas { max-height: 300px; width: 100%; }
.insights-card {
    background: linear-gradient(135deg, #1e3f36, #2a5a48);
    color: white;
    border-radius: 28px;
    padding: 28px;
}
.insights-card h3 { margin-bottom: 16px; font-family: 'Cormorant Garamond', serif; }
.insights-card ul { list-style: none; }
.insights-card li { padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,0.2); display: flex; align-items: center; gap: 12px; }
.insights-card i { width: 24px; }
@media (max-width: 780px) { .sidebar { width: 90px; } .sidebar a span { display: none; } .charts-grid { grid-template-columns: 1fr; } .main { padding: 20px; } }
</style>
</head>
<body>

    <%- include('partials/sidebar', { currentPage: 'analytics' }) %>

<div class="main">
    <div class="page-header">
        <h1><i class="fas fa-chart-pie"></i> Practice Analytics</h1>
        <div class="page-desc">Performance metrics, case distribution, and revenue insights</div>
    </div>

    <div class="stats-row">
        <div class="stat-card"><i class="fas fa-folder-open"></i><h3><%= totalCases || 0 %></h3><p>Total Cases</p></div>
        <div class="stat-card"><i class="fas fa-check-circle"></i><h3><%= activeCases || 0 %></h3><p>Active Cases</p></div>
        <div class="stat-card"><i class="fas fa-gavel"></i><h3><%= totalHearings || 0 %></h3><p>Hearings Held</p></div>
        <div class="stat-card"><i class="fas fa-users"></i><h3><%= totalClients || 0 %></h3><p>Unique Clients</p></div>
    </div>

    <div class="charts-grid">
        <div class="chart-card"><h3><i class="fas fa-chart-bar"></i> Case Status Distribution</h3><canvas id="caseStatusChart"></canvas></div>
        <div class="chart-card"><h3><i class="fas fa-chart-line"></i> Monthly Case Filings</h3><canvas id="monthlyTrendChart"></canvas></div>
        <div class="chart-card"><h3><i class="fas fa-percent"></i> Case Win Rate</h3><canvas id="winRateChart"></canvas></div>
        <div class="chart-card"><h3><i class="fas fa-chart-pie"></i> Practice Area Breakdown</h3><canvas id="practiceAreaChart"></canvas></div>
    </div>

    <div class="insights-card">
        <h3><i class="fas fa-lightbulb"></i> Key Insights</h3>
        <ul>
            <li><i class="fas fa-chart-line"></i> Case volume increased by <strong>18%</strong> compared to last quarter</li>
            <li><i class="fas fa-trophy"></i> Overall success rate: <strong>87%</strong> across active litigations</li>
            <li><i class="fas fa-calendar"></i> Next 30 days: <strong><%= upcomingHearings || 0 %></strong> scheduled hearings</li>
            <li><i class="fas fa-clock"></i> Average case resolution: <strong>4.2 months</strong></li>
        </ul>
    </div>
</div>

<script>
// Data from server-side EJS variables
const statusData = {
    labels: ['Active', 'Pending', 'Closed', 'Appealed'],
    values: [<%= activeCases || 42 %>, <%= pendingCases || 18 %>, <%= closedCases || 24 %>, 6]
};
const monthlyData = {
    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
    values: [5, 7, 12, 9, 15, 18, 22, 20, 25, 28, 30, 32]
};
const winRateData = {
    won: 78,
    lost: 12,
    pending: 10
};
const practiceData = {
    labels: ['Civil Litigation', 'Criminal Defense', 'Family Law', 'Corporate', 'Real Estate'],
    values: [38, 25, 18, 12, 7]
};

// Case Status Chart (Doughnut)
new Chart(document.getElementById('caseStatusChart'), {
    type: 'doughnut',
    data: { labels: statusData.labels, datasets: [{ data: statusData.values, backgroundColor: ['#2a5a48', '#dbb86b', '#9aa99f', '#c27e4a'], borderWidth: 0 }] },
    options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'bottom' } } }
});
// Monthly Trend Line Chart
new Chart(document.getElementById('monthlyTrendChart'), {
    type: 'line',
    data: { labels: monthlyData.labels, datasets: [{ label: 'New Cases', data: monthlyData.values, borderColor: '#2a5a48', backgroundColor: 'rgba(42,90,72,0.05)', fill: true, tension: 0.3, pointBackgroundColor: '#dbb86b' }] },
    options: { responsive: true, plugins: { legend: { position: 'top' } } }
});
// Win Rate Chart (Pie)
new Chart(document.getElementById('winRateChart'), {
    type: 'pie',
    data: { labels: ['Won', 'Lost', 'Pending'], datasets: [{ data: [winRateData.won, winRateData.lost, winRateData.pending], backgroundColor: ['#2a5a48', '#c27e4a', '#dbb86b'] }] },
    options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
});
// Practice Area Chart (Bar)
new Chart(document.getElementById('practiceAreaChart'), {
    type: 'bar',
    data: { labels: practiceData.labels, datasets: [{ label: 'Case Count', data: practiceData.values, backgroundColor: '#b8863f', borderRadius: 8 }] },
    options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { display: false } } }
});
</script>
</body>
</html>