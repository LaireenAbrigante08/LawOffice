<script>
function openModal() {
    const modal = document.getElementById("userModal");
    if(modal) {
        modal.style.display = "flex";
        document.body.style.overflow = "hidden";
    }
}

function closeModal() {
    const modal = document.getElementById("userModal");
    if(modal) {
        modal.style.display = "none";
        document.body.style.overflow = "auto";
    }
}

window.onclick = function(event) {
    const modal = document.getElementById("userModal");
    if (event.target === modal) {
        closeModal();
    }
}

document.addEventListener('keydown', function(e) {
    if (e.key === "Escape") {
        const modal = document.getElementById("userModal");
        if (modal && modal.style.display === "flex") {
            closeModal();
        }
    }
});

// Form Validation
const addForm = document.getElementById('addUserForm');
if(addForm) {
    addForm.addEventListener('submit', function(e) {
        const password = document.getElementById('modalPassword');
        const confirm = document.getElementById('modalConfirmPassword');
        const username = addForm.querySelector('input[name="username"]');
        const fullname = addForm.querySelector('input[name="full_name"]');
        const email = addForm.querySelector('input[name="email"]');
        
        const existing = document.querySelector('.modal-alert-fly');
        if(existing) existing.remove();
        
        if(!fullname.value.trim()) {
            e.preventDefault();
            showModalAlert('Please enter full name.', fullname);
            return false;
        }
        if(!username.value.trim()) {
            e.preventDefault();
            showModalAlert('Please enter a username.', username);
            return false;
        }
        if(!email.value.trim()) {
            e.preventDefault();
            showModalAlert('Please enter an email address.', email);
            return false;
        }
        if(password.value.trim().length < 6) {
            e.preventDefault();
            showModalAlert('Password must be at least 6 characters.', password);
            return false;
        }
        if(password.value !== confirm.value) {
            e.preventDefault();
            showModalAlert('Passwords do not match!', confirm);
            return false;
        }
    });
    
    function showModalAlert(msg, inputField) {
        const existing = document.querySelector('.modal-alert-fly');
        if(existing) existing.remove();
        const alertDiv = document.createElement('div');
        alertDiv.className = 'modal-alert-fly';
        alertDiv.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${msg}`;
        const modalBody = document.querySelector('#userModal .modal-body');
        modalBody.insertBefore(alertDiv, modalBody.firstChild);
        inputField.style.borderColor = '#bc5a4a';
        setTimeout(() => {
            if(alertDiv) alertDiv.remove();
            inputField.style.borderColor = '#e5dbd2';
        }, 3000);
        inputField.focus();
    }
}
</script>