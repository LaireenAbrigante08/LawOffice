<!-- SIDEBAR - Law Firm Portal with Maroon Theme -->
<div class="sidebar">
    <div class="sidebar-header">
        <!-- Real Logo -->
        <img src="/images/bautista-law-logo.png" 
             alt="Bautista Law Office Logo" 
             class="sidebar-logo"
             onerror="this.src='https://via.placeholder.com/58?text=BL';">
        
        <h2>BAUTISTA LAW<br><span>OFFICE PORTAL</span></h2>
    </div>
    
    <div class="sidebar-nav">
        <a href="/dashboard" class="<%= currentPage === 'dashboard' ? 'active' : '' %>">
            <i class="fas fa-tachometer-alt"></i>
            <span>Dashboard</span>
        </a>
        <a href="#" onclick="openModal()">
            <i class="fas fa-user-plus"></i>
            <span>Add User</span>
        </a>
        <a href="/cases" class="<%= currentPage === 'cases' ? 'active' : '' %>">
            <i class="fas fa-folder-open"></i>
            <span>Cases</span>
        </a>
        <a href="/hearings" class="<%= currentPage === 'hearings' ? 'active' : '' %>">
            <i class="fas fa-calendar-alt"></i>
            <span>Hearings</span>
        </a>
        <a href="/court-orders" class="<%= currentPage === 'court-orders' ? 'active' : '' %>">
            <i class="fas fa-file-alt"></i>
            <span>Court Orders</span>
        </a>
        <a href="/analytics" class="<%= currentPage === 'analytics' ? 'active' : '' %>">
            <i class="fas fa-chart-line"></i>
            <span>Analytics</span>
        </a>
        
        <!-- SETTINGS DROPDOWN -->
        <div class="dropdown">
            <a href="#" class="dropdown-toggle" onclick="toggleDropdown(event)">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
                <i class="fas fa-chevron-down" style="margin-left: auto; font-size: 0.7rem;"></i>
            </a>
            <div class="dropdown-menu">
                <a href="#" onclick="openActivityLogsModal(); return false;">
                    <i class="fas fa-history"></i>
                    <span>Activity Logs</span>
                </a>
                <a href="#" onclick="openChangePasswordModal(); return false;">
                    <i class="fas fa-key"></i>
                    <span>Change Password</span>
                </a>
            </div>
        </div>
    </div>
    
    <div class="logout-link">
        <a href="/logout">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </a>
    </div>
</div>

<!-- Add Staff Modal -->
<div class="modal" id="userModal">
    <div class="modal-content" style="width: 700px; max-width: 95%;">
        <div class="modal-header">
            <h3><i class="fas fa-gavel" style="margin-right: 8px;"></i> Register Legal Staff</h3>
            <span class="close" onclick="closeModal()">&times;</span>
        </div>
        <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
            <form method="POST" action="/staff/register" id="addUserForm">
                <!-- Personal Information -->
                <div style="margin-bottom: 20px;">
                    <h4 style="color: #7a2e3a; margin-bottom: 15px; border-bottom: 2px solid #c9865e; padding-bottom: 5px;">
                        <i class="fas fa-user-circle"></i> Personal Information
                    </h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="form-group-modal">
                            <label><i class="fas fa-user"></i> Full Name *</label>
                            <input type="text" name="full_name" placeholder="e.g., Juan M. Dela Cruz" required>
                        </div>
                        <div class="form-group-modal">
                            <label><i class="fas fa-id-card"></i> Username *</label>
                            <input type="text" name="username" placeholder="e.g., juan.delacruz" required>
                        </div>
                        <div class="form-group-modal">
                            <label><i class="fas fa-envelope"></i> Email Address *</label>
                            <input type="email" name="email" placeholder="juan@bautistalaw.com" required>
                        </div>
                        <div class="form-group-modal">
                            <label><i class="fas fa-phone"></i> Phone Number</label>
                            <input type="text" name="phone" placeholder="+63 912 345 6789">
                        </div>
                        <div class="form-group-modal" style="grid-column: span 2;">
                            <label><i class="fas fa-map-marker-alt"></i> Address</label>
                            <textarea name="address" rows="2" placeholder="Office or home address" style="width: 100%; padding: 10px; border: 1.5px solid #e3e2dc; border-radius: 12px;"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Employment Details -->
                <div style="margin-bottom: 20px;">
                    <h4 style="color: #7a2e3a; margin-bottom: 15px; border-bottom: 2px solid #c9865e; padding-bottom: 5px;">
                        <i class="fas fa-briefcase"></i> Employment Details
                    </h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="form-group-modal">
                            <label><i class="fas fa-tag"></i> Position *</label>
                            <select name="position" required style="width: 100%; padding: 12px; border: 1.5px solid #e3e2dc; border-radius: 12px;">
                                <option value="">Select Position</option>
                                <option value="Attorney">Attorney / Lawyer</option>
                                <option value="Paralegal">Paralegal</option>
                                <option value="Legal Assistant">Legal Assistant</option>
                                <option value="Admin Staff">Admin Staff</option>
                                <option value="Secretary">Secretary</option>
                                <option value="Accountant">Accountant</option>
                                <option value="IT Staff">IT Staff</option>
                            </select>
                        </div>
                        <div class="form-group-modal">
                            <label><i class="fas fa-building"></i> Department</label>
                            <select name="department" style="width: 100%; padding: 12px; border: 1.5px solid #e3e2dc; border-radius: 12px;">
                                <option value="">Select Department</option>
                                <option value="Litigation">Litigation</option>
                                <option value="Corporate Law">Corporate Law</option>
                                <option value="Family Law">Family Law</option>
                                <option value="Criminal Law">Criminal Law</option>
                                <option value="Administration">Administration</option>
                                <option value="Finance">Finance</option>
                            </select>
                        </div>
                        <div class="form-group-modal">
                            <label><i class="fas fa-certificate"></i> License/PRC Number</label>
                            <input type="text" name="license_number" placeholder="For attorneys only">
                        </div>
                        <div class="form-group-modal">
                            <label><i class="fas fa-calendar"></i> Hire Date</label>
                            <input type="date" name="hire_date">
                        </div>
                        <div class="form-group-modal">
                            <label><i class="fas fa-toggle-on"></i> Status</label>
                            <select name="status" style="width: 100%; padding: 12px; border: 1.5px solid #e3e2dc; border-radius: 12px;">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="On Leave">On Leave</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Account Security -->
                <div style="margin-bottom: 20px;">
                    <h4 style="color: #7a2e3a; margin-bottom: 15px; border-bottom: 2px solid #c9865e; padding-bottom: 5px;">
                        <i class="fas fa-lock"></i> Account Security
                    </h4>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="form-group-modal">
                            <label><i class="fas fa-key"></i> Password *</label>
                            <input type="password" name="password" id="modalPassword" placeholder="Minimum 6 characters" required>
                        </div>
                        <div class="form-group-modal">
                            <label><i class="fas fa-check-circle"></i> Confirm Password *</label>
                            <input type="password" name="confirm_password" id="modalConfirmPassword" placeholder="Re-enter password" required>
                        </div>
                    </div>
                </div>

                <button class="btn-save" type="submit">
                    <i class="fas fa-save"></i> Register Staff Member
                </button>
                <div class="text-muted">
                    <i class="fas fa-shield-alt"></i> All information will be encrypted and secured
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ACTIVITY LOGS MODAL -->
<div class="modal" id="activityLogsModal">
    <div class="modal-content" style="width: 1000px; max-width: 95%;">
        <div class="modal-header">
            <h3><i class="fas fa-history" style="margin-right: 8px;"></i> Activity Logs</h3>
            <span class="close" onclick="closeActivityLogsModal()">&times;</span>
        </div>
        <div class="modal-body">
            <h4 style="color: #7a2e3a; margin-bottom: 15px;">
                <i class="fas fa-clock"></i> Login & Logout Activity History
            </h4>
            <div style="overflow-x: auto; max-height: 500px; overflow-y: auto; border: 1px solid #e5dbd2; border-radius: 12px;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead style="background: #60212e; color: white; position: sticky; top: 0;">
                        <tr>
                            <th style="padding: 12px; text-align: left;">User</th>
                            <th style="padding: 12px; text-align: left;">Action</th>
                            <th style="padding: 12px; text-align: left;">Date & Time</th>
                            <th style="padding: 12px; text-align: left;">IP Address</th>
                        </tr>
                    </thead>
                    <tbody id="activityLogsBody">
                        <tr><td colspan="4" style="text-align: center; padding: 40px;">Loading activity logs...</td></tr>
                    </tbody>
                </table>
            </div>
            <div style="margin-top: 15px; text-align: right;">
                <button onclick="refreshActivityLogs()" class="btn-save" style="width: auto; padding: 8px 20px; background: #60212e;">
                    <i class="fas fa-sync-alt"></i> Refresh Logs
                </button>
            </div>
        </div>
    </div>
</div>

<!-- CHANGE PASSWORD MODAL -->
<div class="modal" id="changePasswordModal">
    <div class="modal-content" style="width: 500px; max-width: 95%;">
        <div class="modal-header">
            <h3><i class="fas fa-key" style="margin-right: 8px;"></i> Change Password</h3>
            <span class="close" onclick="closeChangePasswordModal()">&times;</span>
        </div>
        <div class="modal-body">
            <form id="changePasswordForm" onsubmit="changePassword(event)">
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #5e3340;">Current Password</label>
                    <input type="password" id="currentPassword" required style="width: 100%; padding: 12px; border: 1.5px solid #e5dbd2; border-radius: 12px;">
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #5e3340;">New Password</label>
                    <input type="password" id="newPassword" required minlength="6" style="width: 100%; padding: 12px; border: 1.5px solid #e5dbd2; border-radius: 12px;">
                    <small style="color: #8a6c6c;">Minimum 6 characters</small>
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-weight: 600; margin-bottom: 8px; color: #5e3340;">Confirm New Password</label>
                    <input type="password" id="confirmNewPassword" required style="width: 100%; padding: 12px; border: 1.5px solid #e5dbd2; border-radius: 12px;">
                </div>
                <button type="submit" class="btn-save">
                    <i class="fas fa-save"></i> Change Password
                </button>
                <div id="passwordChangeMessage" style="margin-top: 15px; font-size: 0.85rem;"></div>
            </form>
        </div>
    </div>
</div>

