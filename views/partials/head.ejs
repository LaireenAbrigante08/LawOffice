<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Google Fonts + Font Awesome 6 -->
<link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    height: 100vh;
    background: linear-gradient(135deg, #eef2f0 0%, #e0e8e3 100%);
    display: flex;
    overflow: hidden;
}

/* ========= SIDEBAR STYLES ========= */
.sidebar {
    width: 280px;
    background: linear-gradient(180deg, #1a3a32 0%, #0f2c24 100%);
    color: #fef5e7;
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    z-index: 10;
}

.sidebar-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(219, 184, 107, 0.3);
}

.sidebar-icon {
    background: #dbb86b;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    box-shadow: 0 6px 12px rgba(0,0,0,0.2);
}

.sidebar-icon i {
    color: #1a3a32;
}

.sidebar-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 1px;
    line-height: 1.2;
    color: #f7eac5;
}

.sidebar-header span {
    font-size: 0.7rem;
    opacity: 0.7;
    display: block;
    font-weight: 400;
}

.sidebar-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 20px;
}

.sidebar a {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 16px;
    color: #e2e6dc;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    border-radius: 14px;
    transition: all 0.25s ease;
    margin: 2px 0;
}

.sidebar a i {
    width: 24px;
    font-size: 1.2rem;
    text-align: center;
}

.sidebar a:hover {
    background: rgba(219, 184, 107, 0.18);
    color: #ffefcf;
    transform: translateX(5px);
}

.sidebar a.active {
    background: #dbb86b;
    color: #1e2f28;
    font-weight: 600;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
}

.sidebar a.active i {
    color: #1a3a32;
}

.logout-link {
    margin-top: auto;
    border-top: 1px solid rgba(219, 184, 107, 0.2);
    padding-top: 20px;
}

.logout-link a {
    color: #f0cf9a;
}

.logout-link a:hover {
    background: rgba(200, 70, 70, 0.15);
    color: #ffbc9a;
}

/* ========= MAIN CONTENT AREA ========= */
.main {
    flex: 1;
    padding: 30px 36px;
    overflow-y: auto;
    scrollbar-width: thin;
}

/* scrollbar */
.main::-webkit-scrollbar {
    width: 6px;
}

.main::-webkit-scrollbar-track {
    background: #e2e8e2;
    border-radius: 10px;
}

.main::-webkit-scrollbar-thumb {
    background: #b49b6c;
    border-radius: 10px;
}

/* ========= MODAL STYLES ========= */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(26, 38, 32, 0.6);
    backdrop-filter: blur(6px);
    justify-content: center;
    align-items: center;
    z-index: 1000;
    animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.modal-content {
    background: white;
    border-radius: 36px;
    width: 420px;
    max-width: 92%;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 35px 55px -20px rgba(0, 0, 0, 0.4);
    animation: slideUp 0.25s cubic-bezier(0.2, 0.9, 0.4, 1.1);
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.modal-header {
    background: #1e3f36;
    padding: 20px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: white;
}

.modal-header h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.2px;
}

.close {
    font-size: 28px;
    cursor: pointer;
    background: rgba(255,255,255,0.12);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 30px;
    transition: all 0.2s;
}

.close:hover {
    background: rgba(255,255,255,0.3);
    transform: scale(1.05);
}

.modal-body {
    padding: 28px 28px 32px;
}

.form-group-modal {
    margin-bottom: 22px;
}

.form-group-modal label {
    display: block;
    font-weight: 600;
    font-size: 0.8rem;
    margin-bottom: 6px;
    color: #3e5b50;
    letter-spacing: 0.3px;
}

.form-group-modal input {
    width: 100%;
    padding: 14px 18px;
    border: 1.5px solid #e3e2dc;
    border-radius: 28px;
    font-size: 0.9rem;
    transition: all 0.2s;
    font-family: 'Inter', sans-serif;
    background: #fefdfa;
}

.form-group-modal input:focus {
    outline: none;
    border-color: #b8863f;
    box-shadow: 0 0 0 3px rgba(184, 134, 63, 0.1);
}

.btn-save {
    width: 100%;
    background: linear-gradient(95deg, #2a5a48, #1e4035);
    padding: 14px;
    border: none;
    border-radius: 44px;
    font-weight: 700;
    color: white;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: all 0.2s;
    margin-top: 12px;
}

.btn-save:hover {
    background: #1c4639;
    transform: translateY(-2px);
}

.text-muted {
    color: #8da094;
    font-size: 0.75rem;
    margin-top: 16px;
    text-align: center;
}

/* responsive */
@media (max-width: 780px) {
    .sidebar {
        width: 90px;
        padding: 20px 12px;
    }
    .sidebar-header h2 span, .sidebar-header h2 br {
        display: none;
    }
    .sidebar-header h2 {
        font-size: 0.9rem;
    }
    .sidebar a span {
        display: none;
    }
    .sidebar a i {
        margin: 0 auto;
        font-size: 1.4rem;
    }
    .sidebar a {
        justify-content: center;
        padding: 12px 0;
    }
    .main {
        padding: 20px;
    }
}
</style>